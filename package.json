{
  "name": "ugc-it-service-request-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node scripts/start-production.mjs",
    "prod:prepare": "npm run db:migrate:pg && npm run build",
    "prod:preflight": "node scripts/prod-preflight.mjs",
    "release": "npm run build && node scripts/make-release.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node scripts/clean.mjs",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:integration": "jest --testPathPatterns=integration",
    "test:coverage": "vitest run --coverage",
    "test:all": "npm run lint && npm run test && npm run test:integration",
    "db:backup": "node scripts/db-backup.mjs",
    "db:restore-latest": "node scripts/db-restore-latest.mjs",
    "db:migrate:pg": "node scripts/db-migrate-postgres.mjs",
    "db:check-migrations": "node scripts/check-migrations.mjs",
    "db:copy:pg": "node scripts/db-copy-sqlite-to-postgres.mjs",
    "pg:backup": "node scripts/pg-backup.mjs",
    "pg:restore": "node scripts/pg-restore.mjs",
    "db:import-officers": "python scripts/import_officers_from_xlsx.py",
    "docs:pdf": "powershell -ExecutionPolicy ByPass -File scripts/BUILD_DOCS_PDF.ps1"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.20.0",
    "picomatch": "^4.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.21.0",
    "vite": "^6.2.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.4.21",
    "jest": "^30.3.0",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.1.14",
    "ts-jest": "^29.4.9",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.4"
  }
}
