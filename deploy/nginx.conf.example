server {
  listen 80;
  server_name example.gov.bd;

  # Redirect all plaintext traffic to HTTPS after TLS is configured.
  return 301 https://$host$request_uri;
}

server {
  listen 443 ssl http2;
  server_name example.gov.bd;

  ssl_certificate     /etc/letsencrypt/live/example.gov.bd/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/example.gov.bd/privkey.pem;

  client_max_body_size 10m;

  location / {
    proxy_pass http://127.0.0.1:3000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_read_timeout 120s;
  }

  location /healthz {
    proxy_pass http://127.0.0.1:3000/healthz;
    proxy_set_header Host $host;
    access_log off;
  }
}
