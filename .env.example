# DATABASE_PATH: Local SQLite file used by the app.
# Relative paths are resolved from the project root.
DATABASE_PATH="./data/database.sqlite"

# PostgreSQL connection string for production.
# Example: postgresql://ugc_app:strong-password@127.0.0.1:5432/ugc_it_service
DATABASE_URL=""

# Production runtime.
PORT=3000
SESSION_TTL_HOURS=12

# Optional persistent upload directory. Relative paths resolve from the project root.
# Use a durable server path in production, not a temporary deploy folder.
UPLOAD_DIR="./public"

# PostgreSQL custom-format backup output folder.
PG_BACKUP_DIR="./pg-backups"

# Optional PostgreSQL bin folder if pg_dump/pg_restore are not in PATH.
# Example: C:/Program Files/PostgreSQL/18/bin
PG_BIN_DIR=""

# Required before creating seed/super-admin users in a real environment.
SUPER_ADMIN_PASSWORD=""
SEED_USER_PASSWORD=""

# Set to require if your PostgreSQL provider requires SSL.
PGSSLMODE=""

# Set to true when running behind a trusted reverse proxy that terminates HTTPS.
TRUST_PROXY=false
